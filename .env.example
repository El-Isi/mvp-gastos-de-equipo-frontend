# ============================================
# Gastos de Equipo — TSO Konfío
# Variables de entorno
# ============================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth Service (Konfío) ---
# Servicio de autenticación JWT
# Docs: ver INTEGRATIONS.md sección 1
AUTH_SERVICE_URL=https://auth.konfio.mx/api/v1
AUTH_SERVICE_API_KEY=your-auth-api-key-here

# --- Notification Service (Konfío) ---
# Servicio de envío de emails y SMS
# Docs: ver INTEGRATIONS.md sección 2
NOTIFICATIONS_URL=https://notifications.konfio.mx/api/v1
NOTIFICATIONS_API_KEY=your-notifications-api-key-here

# --- Database (para persistencia de gastos — futuro) ---
# Actualmente los gastos se almacenan en memoria (mock)
# DATABASE_URL=postgresql://user:password@localhost:5432/gastos_equipo

# --- Session / Cookies ---
# Secreto para firmar cookies de sesión
SESSION_SECRET=your-session-secret-min-32-chars-here
